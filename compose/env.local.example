# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_NAME=AuthEngine
APP_VERSION=1.0.0
DEBUG=True
API_V1_PREFIX=/api/v1
APP_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────
SECRET_KEY=change-me-min-32-chars-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────────
# Databases
# ─────────────────────────────────────────────
POSTGRES_USER=authengine
POSTGRES_PASSWORD=authengine_local_pass
POSTGRES_DB=authengine
POSTGRES_URL=postgresql+asyncpg://authengine:authengine_local_pass@postgres:5432/authengine
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10

MONGO_USER=admin
MONGO_PASSWORD=admin_local_pass
MONGO_DB=authengine
MONGO_AUTH_SOURCE=admin
MONGODB_URL=mongodb://admin:admin_local_pass@mongo:27017/authengine?authSource=admin
MONGODB_DB_NAME=authengine

REDIS_USER=default
REDIS_PASSWORD=redis_local_pass
REDIS_URL=redis://default:redis_local_pass@redis:6379/0
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_SECRET_KEY=change-me-min-32-chars-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ISSUER=authengine
JWT_AUDIENCE=authengine-api

# ─────────────────────────────────────────────
# Super Admin
# ─────────────────────────────────────────────
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=ChangeThisStrongPassword123!

# ─────────────────────────────────────────────
# Password Policy
# ─────────────────────────────────────────────
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=True
PASSWORD_REQUIRE_LOWERCASE=True
PASSWORD_REQUIRE_DIGIT=True
PASSWORD_REQUIRE_SPECIAL=True

# ─────────────────────────────────────────────
# Sessions & Rate Limiting
# ─────────────────────────────────────────────
MAX_CONCURRENT_SESSIONS=5
SESSION_TIMEOUT_MINUTES=60
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=10

# ─────────────────────────────────────────────
# Email — SendGrid
# ─────────────────────────────────────────────
EMAIL_PROVIDER=sendgrid
EMAIL_PROVIDER_API_KEY=
EMAIL_SENDER=noreply@localhost

# ─────────────────────────────────────────────
# SMS — Twilio
# ─────────────────────────────────────────────
SMS_PROVIDER=twilio
SMS_PROVIDER_API_KEY=
SMS_PROVIDER_ACCOUNT_SID=
SMS_SENDER=+1234567890

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ─────────────────────────────────────────────
# OAuth — Google
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback

# ─────────────────────────────────────────────
# OAuth — GitHub
# ─────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/github/callback

# ─────────────────────────────────────────────
# OAuth — Microsoft
# ─────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/microsoft/callback

# ─────────────────────────────────────────────
# OAuth — AuthEngine
# ─────────────────────────────────────────────
AUTHENGINE_BASE_URL=http://localhost:8000
AUTHENGINE_CLIENT_ID=
AUTHENGINE_CLIENT_SECRET=
AUTHENGINE_REDIRECT_URI=http://localhost:3000/oauth/authengine/callback

# ─────────────────────────────────────────────
# Docker Compose
# ─────────────────────────────────────────────
AUTHENGINE_IMAGE_TAG=1.0.0
AUTHENGINE_FRONTEND_IMAGE_TAG=1.0.0
AUTH_ENGINE_SRC=https://github.com/Q-Niranjan/auth-engine.git#main
AUTH_ENGINE_FRONTEND_SRC=https://github.com/Q-Niranjan/auth-engine-frontend.git#main
OIDC_PRIVATE_KEY_PATH=./oidc_private.pem
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
