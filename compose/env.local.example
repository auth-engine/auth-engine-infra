# Local Docker Compose — copy to .env before: docker compose up -d
# cp env.local.example .env

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_NAME=AuthEngine
APP_VERSION=1.0.0
APP_DESCRIPTION=AuthEngine IAM API
DEBUG=True
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
# Public API / OIDC host (API container port)
APP_URL=http://localhost:8000
# Frontend URL for email links (password reset, verify email)
DASHBOARD_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────
# Generate: openssl rand -hex 32
SECRET_KEY=change-me-min-32-chars-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
OIDC_PRIVATE_KEY_PATH=./oidc_private.pem

# ─────────────────────────────────────────────
# Databases — credentials only (URLs are built by docker-compose.yml for the API)
# ─────────────────────────────────────────────
POSTGRES_USER=authengine
POSTGRES_PASSWORD=authengine_local_pass
POSTGRES_DB=authengine
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10
POSTGRES_SSL=False

MONGO_USER=admin
MONGO_PASSWORD=admin_local_pass
MONGO_DB=authengine
MONGO_AUTH_SOURCE=admin
MONGODB_DB_NAME=authengine

REDIS_USER=default
REDIS_PASSWORD=redis_local_pass
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_SECRET_KEY=change-me-min-32-chars-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ISSUER=authengine
JWT_AUDIENCE=authengine-api

# ─────────────────────────────────────────────
# Sessions, rate limiting, AWS
# ─────────────────────────────────────────────
MAX_CONCURRENT_SESSIONS=5
SESSION_TIMEOUT_MINUTES=60
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=10
AWS_REGION=ap-south-1

# ─────────────────────────────────────────────
# WebAuthn / CORS
# ─────────────────────────────────────────────
WEBAUTHN_RP_ID=localhost
CORS_ORIGINS=["http://localhost:3000"]

# ─────────────────────────────────────────────
# Dashboard (NEXT_PUBLIC_* — runtime env for dashboard container)
# ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Leave empty — login page resolves platform tenant from GET /auth/auth-config
NEXT_PUBLIC_PLATFORM_TENANT_ID=

# ─────────────────────────────────────────────
# Seed (auth-engine-data — separate .env.local on your host, not this file)
# auth-engine-data needs a full POSTGRES_URL with localhost (not docker service names):
#   POSTGRES_URL=postgresql+asyncpg://authengine:authengine_local_pass@localhost:5432/authengine
# See auth-engine-data/.env.example
# ─────────────────────────────────────────────
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=ChangeThisStrongPassword123!

# Optional platform-tenant seed (auth-engine-data platform-config / all)
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=
# EMAIL_SENDER=noreply@example.com
