# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_NAME=AuthEngine
APP_VERSION=1.0.0
DEBUG=False
API_V1_PREFIX=/api/v1
APP_URL=https://auth.bestcrmhub.com

# ─────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────
SECRET_KEY=change-me-min-32-chars-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────────
# Databases
# ─────────────────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://USER:PASSWORD@your-rds-host.ap-south-1.rds.amazonaws.com:5432/authengine
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=5

MONGODB_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/authengine?retryWrites=true&w=majority&appName=authengine
MONGODB_DB_NAME=authengine

REDIS_URL=rediss://default:TOKEN@your-instance.upstash.io:6379
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_SECRET_KEY=change-me-min-32-chars-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ISSUER=authengine
JWT_AUDIENCE=authengine-api

# ─────────────────────────────────────────────
# Super Admin
# ─────────────────────────────────────────────
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=ChangeThisStrongPassword123!

# ─────────────────────────────────────────────
# Password Policy
# ─────────────────────────────────────────────
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=True
PASSWORD_REQUIRE_LOWERCASE=True
PASSWORD_REQUIRE_DIGIT=True
PASSWORD_REQUIRE_SPECIAL=True

# ─────────────────────────────────────────────
# Sessions & Rate Limiting
# ─────────────────────────────────────────────
MAX_CONCURRENT_SESSIONS=5
SESSION_TIMEOUT_MINUTES=60
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=10

# ─────────────────────────────────────────────
# Email — SendGrid
# ─────────────────────────────────────────────
EMAIL_PROVIDER=sendgrid
EMAIL_PROVIDER_API_KEY=SG.your-sendgrid-api-key
EMAIL_SENDER=no-reply@yourdomain.com

# ─────────────────────────────────────────────
# SMS — Twilio
# ─────────────────────────────────────────────
SMS_PROVIDER=twilio
SMS_PROVIDER_API_KEY=your-twilio-auth-token
SMS_PROVIDER_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMS_SENDER=+1234567890

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
CORS_ORIGINS=["https://app.bestcrmhub.com"]

# ─────────────────────────────────────────────
# OAuth — Google
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.bestcrmhub.com/api/v1/auth/oauth/google/callback

# ─────────────────────────────────────────────
# OAuth — GitHub
# ─────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://api.bestcrmhub.com/api/v1/auth/oauth/github/callback

# ─────────────────────────────────────────────
# OAuth — Microsoft
# ─────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://api.bestcrmhub.com/api/v1/auth/oauth/microsoft/callback

# ─────────────────────────────────────────────
# OAuth — AuthEngine
# ─────────────────────────────────────────────
AUTHENGINE_BASE_URL=https://api.bestcrmhub.com
AUTHENGINE_CLIENT_ID=
AUTHENGINE_CLIENT_SECRET=
AUTHENGINE_REDIRECT_URI=https://app.bestcrmhub.com/oauth/authengine/callback
