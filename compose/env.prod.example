# ─────────────────────────────────────────────
# Docker Compose (production)
# ─────────────────────────────────────────────
ENV_FILE=/opt/authengine/.env
OIDC_PRIVATE_KEY_PATH=/opt/authengine/oidc_private.pem
AUTHENGINE_IMAGE=qniranjan01/authengine:latest
AUTHENGINE_DASHBOARD_IMAGE=qniranjan01/authengine-dashboard:latest
API_PORT=8000
DASHBOARD_PORT=3000
NODE_ENV=production
HOSTNAME=0.0.0.0

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_NAME=AuthEngine
APP_VERSION=1.0.0
DEBUG=False
API_V1_PREFIX=/api/v1
APP_URL=https://auth.authengine.org
# Public dashboard/frontend URL — used for user-facing email links (password reset, verify email)
DASHBOARD_URL=https://app.authengine.org
# WebAuthn RP ID — registrable parent domain so passkeys work across app.*/auth.* subdomains
WEBAUTHN_RP_ID=authengine.org

# ─────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────
SECRET_KEY=change-me-min-32-chars-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────────
# Databases
# ─────────────────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://USER:PASSWORD@your-rds-host.ap-south-1.rds.amazonaws.com:5432/authengine
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=5

MONGODB_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/authengine?retryWrites=true&w=majority&appName=authengine
MONGODB_DB_NAME=authengine

REDIS_URL=rediss://default:TOKEN@your-instance.upstash.io:6379
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_SECRET_KEY=change-me-min-32-chars-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ISSUER=authengine
JWT_AUDIENCE=authengine-api

# ─────────────────────────────────────────────
# Super Admin
# ─────────────────────────────────────────────
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=ChangeThisStrongPassword123!

# ─────────────────────────────────────────────
# Password Policy
# ─────────────────────────────────────────────
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=True
PASSWORD_REQUIRE_LOWERCASE=True
PASSWORD_REQUIRE_DIGIT=True
PASSWORD_REQUIRE_SPECIAL=True

# ─────────────────────────────────────────────
# Sessions & Rate Limiting
# ─────────────────────────────────────────────
MAX_CONCURRENT_SESSIONS=5
SESSION_TIMEOUT_MINUTES=60
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=10

# ─────────────────────────────────────────────
# Email — Amazon SES (primary)
# ─────────────────────────────────────────────
# Verify authengine.org in SES (see terraform/ses.tf). Leave the API key blank to
# use the EC2 IAM role (recommended). Otherwise set "ACCESS_KEY_ID:SECRET_ACCESS_KEY".
EMAIL_PROVIDER=ses
EMAIL_PROVIDER_API_KEY=
EMAIL_SENDER=noreply@authengine.org
AWS_REGION=ap-south-1

# Alternative — SendGrid
# EMAIL_PROVIDER=sendgrid
# EMAIL_PROVIDER_API_KEY=SG.your-sendgrid-api-key

# ─────────────────────────────────────────────
# SMS — Android Phone + SIM gateway (primary)
# ─────────────────────────────────────────────
# On EC2 you MUST use the app's Cloud mode (the server cannot reach a phone's LAN IP).
SMS_PROVIDER=android_gateway
SMS_GATEWAY_URL=https://api.sms-gate.app/3rdparty/v1
SMS_GATEWAY_USERNAME=your-gateway-username
SMS_GATEWAY_PASSWORD=your-gateway-password

# Alternative — Twilio
# SMS_PROVIDER=twilio
# SMS_PROVIDER_API_KEY=your-twilio-auth-token
# SMS_PROVIDER_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SMS_SENDER=+1234567890

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
CORS_ORIGINS=["https://app.authengine.org"]

# ─────────────────────────────────────────────
# OAuth — Google
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.authengine.org/api/v1/auth/oauth/google/callback

# ─────────────────────────────────────────────
# OAuth — GitHub
# ─────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://api.authengine.org/api/v1/auth/oauth/github/callback

# ─────────────────────────────────────────────
# OAuth — Microsoft
# ─────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://api.authengine.org/api/v1/auth/oauth/microsoft/callback

# ─────────────────────────────────────────────
# OAuth — AuthEngine
# ─────────────────────────────────────────────
AUTHENGINE_BASE_URL=https://api.authengine.org
AUTHENGINE_CLIENT_ID=
AUTHENGINE_CLIENT_SECRET=
AUTHENGINE_REDIRECT_URI=https://app.authengine.org/oauth/authengine/callback